{
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "lib": ["DOM", "ES2022"],
    "module": "ESNext",
    "moduleDetection": "force",
    "moduleResolution": "bundler",
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": []
  },
  "include": ["**/*.ts", "types.d.ts"]
}
